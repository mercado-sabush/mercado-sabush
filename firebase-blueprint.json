{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "seller", "admin"] },
        "isBanned": { "type": "boolean" },
        "phoneNumber": { "type": "string" },
        "location": { "type": "string" },
        "country": { "type": "string" },
        "currency": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Store": {
      "title": "Store",
      "description": "Seller's business information",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "businessName": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "logo": { "type": "string" },
        "banner": { "type": "string" },
        "location": { "type": "string" },
        "country": { "type": "string" },
        "currency": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "whatsappNumber": { "type": "string" },
        "deliveryOptions": { "type": "string", "enum": ["pickup", "delivery", "both"] },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "active", "suspended"] }
      },
      "required": ["ownerId", "businessName", "category"]
    },
    "Product": {
      "title": "Product",
      "description": "Marketplace product listing",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "sellerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "minOrderQuantity": { "type": "number" },
        "wholesalePrices": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "minQuantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "deliveryAvailable": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "hidden", "out_of_stock"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "name", "price", "category"]
    },
    "RFQ": {
      "title": "RFQ",
      "description": "Request for Quotation from customer to seller",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "storeId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "responded", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "storeId", "productId", "quantity", "status"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "User's favorited products (Wishlist)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review and rating",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "productCount": { "type": "number" },
        "sellerCount": { "type": "number" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase transaction",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "storeId": { "type": "string" },
        "productIds": { "type": "array", "items": { "type": "string" } },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "processing", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["mpesa", "emola", "card", "cod", "bank"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "deliveryMethod": { "type": "string", "enum": ["pickup", "delivery"] },
        "deliveryAddress": { "type": "string" },
        "country": { "type": "string" },
        "currency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "storeId", "totalAmount", "status"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Real-time communication between buyer and seller",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "orderId": { "type": "string" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual chat message",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications for orders and chats",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["order", "chat", "mpesa"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message"]
    },
    "Report": {
      "title": "Report",
      "description": "User reports for violations",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "targetId": { "type": "string" },
        "targetType": { "type": "string", "enum": ["user", "store", "product"] },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "ignored"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterId", "targetId", "targetType", "reason", "status"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "stores": {
      "schema": "Store",
      "description": "Collection of seller stores"
    },
    "products": {
      "schema": "Product",
      "description": "All marketplace product listings"
    },
    "categories": {
      "schema": "Category",
      "description": "Available product categories"
    },
    "orders": {
      "schema": "Order",
      "description": "Purchase orders placed by customers"
    },
    "chats": {
      "schema": "Chat",
      "description": "Active chat conversations"
    },
    "notifications": {
      "schema": "Notification",
      "description": "System and user notifications"
    },
    "reports": {
      "schema": "Report",
      "description": "User reports for violations"
    },
    "rfqs": {
      "schema": "RFQ",
      "description": "Business inquiries and quote requests"
    },
    "favorites": {
      "schema": "Favorite",
      "description": "Items saved to wishlist by users"
    },
    "reviews": {
      "schema": "Review",
      "description": "Customer reviews for products"
    }
  }
}
